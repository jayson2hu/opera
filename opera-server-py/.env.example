# Server port (optional, defaults to 3001)
PORT=3001

# AI Provider
# Default provider: "anthropic" | "deepseek" | "custom"
AI_PROVIDER=anthropic

# Anthropic (when AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-xxxxx
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# DeepSeek (when AI_PROVIDER=deepseek)
DEEPSEEK_API_KEY=sk-xxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Custom OpenAI-compatible provider (when AI_PROVIDER=custom)
# Use this for any third-party proxy / relay site
CUSTOM_API_KEY=sk-xxxxx
CUSTOM_BASE_URL=https://your-proxy.com/v1
CUSTOM_MODEL=gpt-4o
