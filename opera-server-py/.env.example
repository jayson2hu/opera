# Server port (optional, defaults to 3001)
PORT=3001

# AI Provider
# Default provider: "anthropic" | "anthropic_compat" | "openai" | "openai_compat" | "deepseek" | "custom"
AI_PROVIDER=anthropic

# Anthropic (when AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-xxxxx
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MODELS=claude-sonnet-4-20250514

# Third-party Anthropic-compatible Claude gateway (when AI_PROVIDER=anthropic_compat)
ANTHROPIC_COMPAT_API_KEY=sk-xxxxx
ANTHROPIC_COMPAT_BASE_URL=https://your-claude-gateway.com
ANTHROPIC_COMPAT_MODEL=claude-sonnet-4-20250514
ANTHROPIC_COMPAT_MODELS=claude-sonnet-4-20250514

# OpenAI official ChatGPT/GPT models (when AI_PROVIDER=openai)
OPENAI_API_KEY=sk-xxxxx
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-5.2
OPENAI_CHATGPT_MODEL=gpt-5.2-chat-latest
OPENAI_MODELS=gpt-5.2,gpt-5.2-chat-latest

# Third-party OpenAI-compatible ChatGPT/GPT gateway (when AI_PROVIDER=openai_compat)
OPENAI_COMPAT_API_KEY=sk-xxxxx
OPENAI_COMPAT_BASE_URL=https://your-openai-gateway.com/v1
OPENAI_COMPAT_MODEL=gpt-4o
OPENAI_COMPAT_MODELS=gpt-4o,gpt-5.2

# DeepSeek (when AI_PROVIDER=deepseek)
DEEPSEEK_API_KEY=sk-xxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MODELS=deepseek-chat

# Legacy custom OpenAI-compatible provider (when AI_PROVIDER=custom)
# Prefer OPENAI_COMPAT_* for new third-party OpenAI-compatible gateways.
CUSTOM_API_KEY=sk-xxxxx
CUSTOM_BASE_URL=https://your-proxy.com/v1
CUSTOM_MODEL=gpt-4o
CUSTOM_MODELS=gpt-4o
